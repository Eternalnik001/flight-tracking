# Copy to .env (gitignored) and fill in. Real env vars / CI secrets override these.

# --- cached broad scan ---
TRAVELPAYOUTS_TOKEN=your_travelpayouts_token

# --- gated live confirmation ---
SERPAPI_KEY=your_serpapi_key

# --- state (survives between CI runs) ---
# Local: omit to use sqlite:///flights.db
# CI: use the Supabase SESSION POOLER string (IPv4), not the direct (IPv6) host.
# DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres?sslmode=require

# --- email (optional) ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
EMAIL_FROM=Flight Tracker <onboarding@resend.dev>
EMAIL_TO=you@example.com

# --- trip definition (optional; defaults shown) ---
TRIP_YEAR=2026
TRIP_MONTHS=8,11
